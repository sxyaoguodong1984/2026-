    # ====================== 一键保存（保存到 E 盘） ======================
    def onekey_save_pan(self):
        # 保存路径固定为 E 盘
        save_path = "E:/qimen_last_save.json"

        data = {
            "circle_angles": self.circle_angles,
            "current_stars": self.current_stars,
            "current_doors": self.current_doors,
            "current_shen": self.current_shen,
            "star_by_num": self.star_by_num,
            "current_shen_shun": self.current_shen_shun,
            "current_shen_ni": self.current_shen_ni,
            "jiugong_info_text1": self.jiugong_info_input1.get(),
            "jiugong_info_text2": self.jiugong_info_input2.get(),
            "tian_gang_selections": {item["num"]: item["combobox"].get() for item in self.tg_comboboxes}
        }
        try:
            with open(save_path, "w", encoding="utf-8") as f:
                json.dump(data, f, ensure_ascii=False, indent=4)
            messagebox.showinfo("保存成功", "✅ 当前排盘已保存到 E 盘！\n下次打开自动恢复！")
        except Exception as e:
            messagebox.showerror("保存失败", str(e))

    # ====================== 自动加载（从 E 盘读取） ======================
    def autoload_last_pan(self):
        # 加载路径固定为 E 盘
        save_path = "E:/qimen_last_save.json"

        if not os.path.exists(save_path):
            return
        try:
            with open(save_path, "r", encoding="utf-8") as f:
                data = json.load(f)

            self.circle_angles = data.get("circle_angles", [0] * 4)
            self.current_stars = data.get("current_stars", self.current_stars)
            self.current_doors = data.get("current_doors", self.current_doors)
            self.current_shen = data.get("current_shen", self.current_shen)
            self.star_by_num = data.get("star_by_num", self.star_by_num)
            self.current_shen_shun = data.get("current_shen_shun", self.current_shen_shun)
            self.current_shen_ni = data.get("current_shen_ni", self.current_shen_ni)

            if "jiugong_info_text1" in data:
                self.jiugong_info_input1.delete(0, tk.END)
                self.jiugong_info_input1.insert(0, data["jiugong_info_text1"])
            if "jiugong_info_text2" in data:
                self.jiugong_info_input2.delete(0, tk.END)
                self.jiugong_info_input2.insert(0, data["jiugong_info_text2"])

            tg_data = data.get("tian_gang_selections", {})
            for item in self.tg_comboboxes:
                val = tg_data.get(item["num"], self.tian_gang_list[0])
                if val in self.tian_gang_list:
                    item["combobox"].current(self.tian_gang_list.index(val))

            self.draw_all_circles()
            self.draw_jiugong_grid()
        except:
            pass

