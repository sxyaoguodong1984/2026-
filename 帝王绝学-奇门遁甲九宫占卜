    def file_open(self):
        file_path = filedialog.askopenfilename(
            title="打开配置文件",
            filetypes=[("JSON文件", "*.json"), ("所有文件", "*.*")]
        )
        if file_path:
            try:
                with open(file_path, "r", encoding="utf-8") as f:
                    data = json.load(f)
                self.circle_angles = data.get("circle_angles", [0, 0, 0, 0])
                self.current_stars = data.get("current_stars", self.get_star_list())
                self.current_doors = data.get("current_doors", self.current_doors)
                self.current_shen = data.get("current_shen", self.current_shen_shun.copy())
                if "jiugong_info_text1" in data:
                    self.jiugong_info_input1.delete(0, tk.END)
                    self.jiugong_info_input1.insert(0, data["jiugong_info_text1"])
                if "jiugong_info_text2" in data:
                    self.jiugong_info_input2.delete(0, tk.END)
                    self.jiugong_info_input2.insert(0, data["jiugong_info_text2"])
                tg_selections = data.get("tian_gang_selections", {})
                for item in self.tg_comboboxes:
                    num = item["num"]
                    if num in tg_selections:
                        if tg_selections[num] in self.tian_gang_list:
                            idx = self.tian_gang_list.index(tg_selections[num])
                        else:
                            idx = 0
                        item["combobox"].current(idx)
                self.draw_all_circles()
                self.draw_jiugong_grid()
                self.file_path = file_path
                messagebox.showinfo("成功", "配置文件加载成功！")
            except Exception as e:
                messagebox.showerror("错误", f"打开文件失败：{str(e)}")

    def file_save(self):
        if not self.file_path:
            self.file_save_as()
            return
        try:
            jiugong_info_text1 = self.jiugong_info_input1.get()
            jiugong_info_text2 = self.jiugong_info_input2.get()
            tg_selections = {}
            for item in self.tg_comboboxes:
                tg_selections[item["num"]] = item["combobox"].get()
            data = {
                "circle_angles": self.circle_angles,
                "current_stars": self.current_stars,
                "current_doors": self.current_doors,
                "current_shen": self.current_shen,
                "tian_gang_selections": tg_selections,
                "jiugong_info_text1": jiugong_info_text1,
                "jiugong_info_text2": jiugong_info_text2
            }
            with open(self.file_path, "w", encoding="utf-8") as f:
                json.dump(data, f, ensure_ascii=False, indent=4)
            messagebox.showinfo("成功", "配置已保存！")
        except Exception as e:
            messagebox.showerror("错误", f"保存失败：{str(e)}")

