    def get_current_jieqi(self):
        now = datetime.now()
        now_date = now.date()
        if now < self.jieqi_2026[0][1]:
            return "冬至", "下元"
        for jieqi_name, start_time, end_time in self.jieqi_2026:
            jieqi_day = start_time.date()
            next_jieqi_day = end_time.date()
            if jieqi_day <= now_date < next_jieqi_day:
                day_diff = (now_date - jieqi_day).days
                if day_diff <= 5:
                    yuan = "上元"
                elif day_diff <= 10:
                    yuan = "中元"
                else:
                    yuan = "下元"
                return jieqi_name, yuan
        return "小寒", "上元"

    def get_jieqi_dun_num(self, jieqi_name, yuan):
        yangdun_rules = {
            "冬至": {"上元": "一", "中元": "七", "下元": "四"},
            "惊蛰": {"上元": "一", "中元": "七", "下元": "四"},
            "小寒": {"上元": "二", "中元": "八", "下元": "五"},
            "大寒": {"上元": "三", "中元": "九", "下元": "六"},
            "春分": {"上元": "三", "中元": "九", "下元": "六"},
            "立春": {"上元": "八", "中元": "五", "下元": "二"},
            "谷雨": {"上元": "五", "中元": "二", "下元": "八"},
            "小满": {"上元": "五", "中元": "二", "下元": "八"},
            "雨水": {"上元": "九", "中元": "六", "下元": "三"},
            "清明": {"上元": "四", "中元": "一", "下元": "七"},
            "立夏": {"上元": "四", "中元": "一", "下元": "七"},
            "芒种": {"上元": "六", "中元": "三", "下元": "九"}
        }
        yindun_rules = {
            "夏至": {"上元": "九", "中元": "三", "下元": "六"},
            "白露": {"上元": "九", "中元": "三", "下元": "六"},
            "小暑": {"上元": "八", "中元": "二", "下元": "五"},
            "大暑": {"上元": "七", "中元": "一", "下元": "四"},
            "秋分": {"上元": "七", "中元": "一", "下元": "四"},
            "立秋": {"上元": "二", "中元": "五", "下元": "八"},
            "霜降": {"上元": "五", "中元": "八", "下元": "二"},
            "小雪": {"上元": "五", "中元": "八", "下元": "二"},
            "处暑": {"上元": "一", "中元": "四", "下元": "七"},
            "寒露": {"上元": "九", "中元": "六", "下元": "三"},
            "立冬": {"上元": "九", "中元": "六", "下元": "三"},
            "大雪": {"上元": "四", "中元": "七", "下元": "一"}
        }
        if jieqi_name in yangdun_rules:
            dun_type = "阳遁"
            dun_num = yangdun_rules[jieqi_name].get(yuan, "一")
        elif jieqi_name in yindun_rules:
            dun_type = "阴遁"
            dun_num = yindun_rules[jieqi_name].get(yuan, "九")
        else:
            dun_type = "阳遁"
            dun_num = "一"
        return dun_type, dun_num

    def update_jieqi_info(self):
        try:
            jieqi_name, yuan = self.get_current_jieqi()
            dun_type, dun_num = self.get_jieqi_dun_num(jieqi_name, yuan)
            display_text = f"{jieqi_name} {yuan}{dun_num}局（{dun_type}）"
            current_text = self.jiugong_info_input1.get()
            if current_text != display_text:
                self.jiugong_info_input1.delete(0, tk.END)
                self.jiugong_info_input1.insert(0, display_text)
        except:
            self.jiugong_info_input1.delete(0, tk.END)
            self.jiugong_info_input1.insert(0, "冬至 上元一局（阳遁）")
        self.root.after(60000, self.update_jieqi_info)

    def update_current_hour(self):
        now = datetime.now()
        hour = now.hour
        minute = now.minute
        second = now.second
        if 23 <= hour or hour < 1:
            current_hour = "子时"
        elif 1 <= hour < 3:
            current_hour = "丑时"
        elif 3 <= hour < 5:
            current_hour = "寅时"
        elif 5 <= hour < 7:
            current_hour = "卯时"
        elif 7 <= hour < 9:
            current_hour = "辰时"
        elif 9 <= hour < 11:
            current_hour = "巳时"
        elif 11 <= hour < 13:
            current_hour = "午时"
        elif 13 <= hour < 15:
            current_hour = "未时"
        elif 15 <= hour < 17:
            current_hour = "申时"
        elif 17 <= hour < 19:
            current_hour = "酉时"
        elif 19 <= hour < 21:
            current_hour = "戌时"
        elif 21 <= hour < 23:
