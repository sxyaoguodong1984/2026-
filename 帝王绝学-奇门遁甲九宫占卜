    def draw_all_circles(self):
        self.circle_canvas.delete("all")
        for circle_idx in range(4):
            radius = self.base_radius + (3 - circle_idx) * self.radius_gap
            self.circle_canvas.create_oval(
                self.center_x - radius, self.center_y - radius,
                self.center_x + radius, self.center_y + radius,
                outline="black", width=2
            )
            rotate_angle = self.circle_angles[circle_idx]
            for line_angle in self.line_mid_angles:
                total_angle = line_angle + rotate_angle
                angle_rad = math.radians(total_angle)
                line_x = self.center_x + self.max_radius * math.cos(angle_rad)
                line_y = self.center_y - self.max_radius * math.sin(angle_rad)
                self.circle_canvas.create_line(
                    self.center_x, self.center_y,
                    line_x, line_y,
                    fill="gray", width=1
                )
            font_size = int(12 + (radius - self.base_radius) * 0.08)
            font_size = max(12, min(20, font_size))
            for idx, bagua_name in enumerate(self.bagua_names):
                text_angle = self.bagua_angles[idx] + rotate_angle
                angle_rad = math.radians(text_angle)
                text_radius = radius - (18 if circle_idx == 3 else 28)
                text_x = self.center_x + text_radius * math.cos(angle_rad)
                text_y = self.center_y - text_radius * math.sin(angle_rad)
                self.circle_canvas.create_text(
                    text_x, text_y,
                    text=bagua_name,
                    font=("SimHei", font_size, "bold"),
                    fill="black",
                    anchor="center"
                )

    def draw_jiugong_grid(self):
        self.jiugong_canvas.delete("all")
        side_length = self.max_diameter
        cell_size = side_length / 3
        label_offset = 15
        shen_offset = 30
        self.jiugong_canvas.create_rectangle(0, 0, side_length, side_length, outline="black", width=2)
        self.jiugong_canvas.create_line(cell_size, 0, cell_size, side_length, fill="black", width=1)
        self.jiugong_canvas.create_line(2 * cell_size, 0, 2 * cell_size, side_length, fill="black", width=1)
        self.jiugong_canvas.create_line(0, cell_size, side_length, cell_size, fill="black", width=1)
        self.jiugong_canvas.create_line(0, 2 * cell_size, side_length, 2 * cell_size, fill="black", width=1)
        idx = 0
        for row in range(3):
            for col in range(3):
                x1 = col * cell_size
                y1 = row * cell_size
                mid_x = (x1 + (col + 1) * cell_size) / 2
                mid_y = (y1 + (row + 1) * cell_size) / 2
                shen_text = self.current_shen[idx]
                if idx == 4 and (shen_text == "直符" or self.current_stars[idx] == "天禽星"):
                    shen_display_text = "直符"
                else:
                    shen_display_text = shen_text
                self.jiugong_canvas.create_text(
                    mid_x, mid_y - shen_offset - 5,
                    text=shen_display_text,
                    font=("SimHei", 9, "bold"),
                    fill="darkgreen",
                    anchor="center"
                )
                self.jiugong_canvas.create_text(
                    mid_x, mid_y - label_offset - 5,
                    text=self.current_stars[idx],
                    font=("SimHei", 10, "bold"),
                    fill="darkblue",
                    anchor="center"
                )
                self.jiugong_canvas.create_text(
                    mid_x, mid_y,
                    text=self.base_nums[idx],
                    font=("SimHei", 14, "bold"),
                    fill="black",
                    anchor="center"
                )
                self.jiugong_canvas.create_text(
                    mid_x, mid_y + label_offset + 5,
                    text=self.current_doors[idx],
                    font=("SimHei", 10, "bold"),
                    fill="darkred",
                    anchor="center"
                )
                idx += 1

    def move_stars(self, direction="forward"):
        current_star_num = {num: self.star_by_num[num] for num in self.star_by_num.keys()}
        if direction == "forward":
            num_order = ["一", "二", "三", "四", "五", "六", "七", "八", "九"]
        else:
            num_order = ["九", "八", "七", "六", "五", "四", "三", "二", "一"]
        new_star_num = {}
        for i in range(len(num_order)):
            current_num = num_order[i]
            prev_num = num_order[i - 1]
            new_star_num[current_num] = current_star_num[prev_num]
        self.star_by_num = new_star_num
        self.current_stars = self.get_star_list()
        self.draw_jiugong_grid()

    def change_doors(self, direction="forward"):
        map_key = "顺时针" if direction == "forward" else "逆时针"
        new_doors = [self.current_doors[i] for i in self.door_rotate_map[map_key]]
        new_doors[4] = "困位"
        self.current_doors = new_doors
        self.draw_jiugong_grid()

    def change_shen(self, direction="forward"):
        map_key = "顺时针" if direction == "forward" else "逆时针"
        if direction == "forward":
            self.current_shen = self.current_shen_shun.copy()
        else:
            self.current_shen = self.current_shen_ni.copy()
        new_shen = [self.current_shen[i] for i in self.shen_rotate_map[map_key]]
        new_shen[4] = self.current_shen[4]
        if direction == "forward":
            self.current_shen_shun = new_shen
        else:
            self.current_shen_ni = new_shen
        self.current_shen = new_shen
        self.draw_jiugong_grid()

    def rotate_circle(self, circle_idx):
        self.circle_angles[circle_idx] = (self.circle_angles[circle_idx] + self.rotate_step) % 360
        self.draw_all_circles()


